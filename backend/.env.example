# Required Core App Configurations
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/pos_auth_db
JWT_SECRET=supersecret_jwt_sign_key_change_in_production_12345
JWT_EXPIRE=24h
COOKIE_EXPIRE=24
CLIENT_URL=http://localhost:5173

# SMTP Email Config (e.g. Mailtrap)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
SMTP_FROM=noreply@smartpos.com

# Invite Codes for RBAC Registration
SUPER_ADMIN_INVITE=SUPER2026
ADMIN_INVITE=ADMIN2026
